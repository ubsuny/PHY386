{
  "name": "PHY386 Python Environment",
  "image": "mcr.microsoft.com/devcontainers/python:3.12-bookworm",

  "features": {
    "ghcr.io/devcontainers/features/git:1": {}
  },

  "customizations": {
    "vscode": {
      "extensions": [
        "ms-python.python",
        "ms-toolsai.jupyter",
        "ms-python.vscode-pylance",
        "github.copilot"
      ],
      "settings": {
        "python.defaultInterpreterPath": "/usr/local/bin/python",
        "python.analysis.typeCheckingMode": "basic",
        "jupyter.interactiveWindow.textEditor.executeSelection": true
      }
    }
  },

  "postCreateCommand": "pip install -r requirements/requirements_HW2026.txt && python -m ipykernel install --user --name python3 --display-name 'Python 3'",

  "remoteUser": "vscode"
}
