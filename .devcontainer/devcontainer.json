{
  "name": "PHY386 Python Environment",
  "image": "mcr.microsoft.com/devcontainers/python:3.13",

  "features": {
    "ghcr.io/devcontainers/features/git:1": {},
    "ghcr.io/devcontainers/features/python": {"installJupyterlab": true}
  },

  "customizations": {
    "vscode": {
      "extensions": [
        "ms-python.python",
        "ms-toolsai.jupyter",
        "ms-python.vscode-pylance",
        "eamodio.gitlens"
      ],
      "settings": {
        "python.defaultInterpreterPath": "/usr/local/bin/python",
        "jupyter.interactiveWindow.textEditor.executeSelection": true
      }
    }
  },

  "postCreateCommand": "pip install -r requirements/requirements_HW2026.txt",

  "forwardPorts": [8888],

  "remoteUser": "vscode"
}
